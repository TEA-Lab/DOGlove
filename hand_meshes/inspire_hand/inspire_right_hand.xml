<mujoco model="inspire right hand">
    <statistic center="0.3 0 0.4" extent="1"/>
    <compiler angle="radian" meshdir=".." autolimits="true"/>

    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
        <rgba haze="0.15 0.25 0.35 1"/>
        <global azimuth="120" elevation="20"/>
    </visual>

    <default>
        <joint damping="3"/>
        <muscle ctrllimited="true" ctrlrange="0 100"/>
        <motor ctrllimited="true" ctrlrange="-3 3" />
        <position ctrllimited="true" kp="10"/>
    </default>

    <asset>
        <mesh name="palm_vis" file="meshes/hand_base_link.STL"/>
        <mesh name="palm_col" file="meshes/hand_base_link.STL"/>
        <!-- <mesh name="palm_vis" file="meshes/base_link.STL"/>
        <mesh name="palm_col" file="meshes/base_link.STL"/> -->

        <mesh name="thumb_proximal_1_vis" file="meshes/Link11.STL"/>
        <mesh name="thumb_proximal_1_col" file="meshes/Link11.STL"/>

        <mesh name="thumb_proximal_2_vis" file="meshes/Link12.STL"/>
        <mesh name="thumb_proximal_2_col" file="meshes/Link12.STL"/>

        <mesh name="thumb_middle_vis" file="meshes/Link13.STL"/>
        <mesh name="thumb_middle_col" file="meshes/Link13.STL"/>


        <mesh name="thumb_distal_vis" file="meshes/Link14.STL"/>
        <mesh name="thumb_distal_col" file="meshes/Link14.STL"/>

        <mesh name="index_proximal_vis" file="meshes/Link15.STL"/>
        <mesh name="index_proximal_col" file="meshes/Link15.STL"/>

        <mesh name="index_distal_vis" file="meshes/Link16.STL"/>
        <mesh name="index_distal_col" file="meshes/Link16.STL"/>

        <mesh name="middle_proximal_vis" file="meshes/Link17.STL"/>
        <mesh name="middle_proximal_col" file="meshes/Link17.STL"/>

        <mesh name="middle_distal_vis" file="meshes/Link18.STL"/>
        <mesh name="middle_distal_col" file="meshes/Link18.STL"/>


        <mesh name="ring_proximal_vis" file="meshes/Link19.STL"/>
        <mesh name="ring_proximal_col" file="meshes/Link19.STL"/>

        <mesh name="ring_distal_vis" file="meshes/Link20.STL"/>
        <mesh name="ring_distal_col" file="meshes/Link20.STL"/>


        <mesh name="pinky_proximal_vis" file="meshes/Link21.STL"/>
        <mesh name="pinky_proximal_col" file="meshes/Link21.STL"/>

        <mesh name="pinky_distal_vis" file="meshes/Link22.STL"/>
        <mesh name="pinky_distal_col" file="meshes/Link22.STL"/>

        <material name="site_right_hand" rgba="0.1882 0.1882 0.1882 0"/>

        <material name="base_material" rgba="0 0 0 1"/>
        <material name="thumb_material" rgba="0 0 0 1"/>
        <material name="index_material" rgba="0 0 0 1"/>
        <material name="middle_material" rgba="0 0 0 1"/>
        <material name="ring_material" rgba="0 0 0 1"/>
        <material name="pinky_material" rgba="0 0 0 1"/>

        <material name="thumb_distal_material" rgba="0 0 0 1"/>

    </asset>

    <worldbody> 
        <body name="right_hand" pos="0.0 0 0.15" euler="1.57 3.14 3.14">
        <!-- <body name="right_hand" pos="0.5 0.5 0.5" quat="0.7071068 0 0 -0.7071068"> -->
            <site name="ft_frame" pos="0 0 0" size="0.01 0.01 0.01" rgba="1 0 0 0" type="sphere" group="1"/>
            <!-- <site name="attachment_site" size="0.01" pos="-0.05 0.0 0.0" quat="-1 1 1 1" rgba="1 0 0 1" group="1"/> -->
            <inertial diaginertia="0 0 0" mass="0" pos="0 0 0"/>
            <!-- <body name="eef" pos="0 0 0" euler="1.57 0 0">
                <site name="grip_site" pos="0 0 0" size="0.01 0.01 0.01" rgba="1 1 0 1" type="sphere" group="2"/>
                <site name="ee_y" pos="0.1 0 0" size="0.005 0.005" euler="0 0 -1.57" rgba="1 0 0 1" type="cylinder" group="4"/>
                <site name="ee_z" pos="0 0.1 0" size="0.005 0.005" euler="0 1.57 0" rgba="0 1 0 1" type="cylinder" group="4"/>
                <site name="ee_x" pos="0 0 0.1" size="0.005 0.005" euler="1.57 0 0" rgba="0 0 1 1" type="cylinder" group="4"/>
            </body> -->


            <!-- Palm  -->
            <body name="palm" pos="0 0 0">
                <!-- <inertial pos="-0.0014004 -0.052388 -0.0022404" quat="1 0 0 0" mass="0.10331">
                    <inertia ixx="9.814E-05" ixy="3.1871E-06" ixz="-1.475E-06" iyy="6.4612E-05" iyz="2.4108E-06" izz="5.5131E-05"/>
                </inertial> -->
                <!-- Palm Visual -->
                <geom name="palm_vis" type="mesh" mesh="palm_vis" material="base_material" group="1" contype="0" conaffinity="0"/>
                <!-- Palm Collision -->
                <geom name="palm_col" type="mesh" mesh="palm_col" mass="0.1" />

                <!-- Thumb -->
                <body name="thumb" pos="0. 0. 0.">
                    <!-- Thumb Proximal 1 -->
                    <!-- <body name="thumb_proximal_1" pos="-0.01496 -0.0375 -0.02045" quat="0.5 0.5 -0.5 0.5"> -->
                    <body name="thumb_proximal_1" pos="-0.0157 -0.0625 -0.02045" quat="0.5 0.5 -0.5 0.5">
                        <joint name="joint_thumb_proximal_1" type="hinge" pos="0 0 0" axis="0 0 -1" range="0 1.30" limited="true" damping="3"/>
                        <!-- <site name="site_thumb_proximal_1" size="0.01" material="site_right_hand"/> -->
                        <geom name="thumb_proximal_vis" type="mesh" mesh="thumb_proximal_1_vis" material="thumb_material" group="1" contype="0" conaffinity="0"> </geom>
                        <geom name="thumb_proximal_col" type="mesh" mesh="thumb_proximal_1_col" mass="0.1" />

                        <!-- Thumb Proximal 2 -->
                        <body name="thumb_proximal_2" pos="-0.0088099 0.010892 -0.00925" quat="0.1 0.1 0.7 0.7">
                            <joint name="joint_thumb_proximal_2" type="hinge" pos="0 0 0" axis="0 0 1" range="0 0.68" limited="true" damping="3" />
                            <geom name="thumb_proximal_2_vis" type="mesh" mesh="thumb_proximal_2_vis" material="thumb_material" group="1" contype="0" conaffinity="0"> </geom>
                            <geom name="thumb_proximal_2_col" type="mesh" mesh="thumb_proximal_2_col" mass="0.1" />

                            <site name="site_thumb_proximal_2" size="0.01" material="site_right_hand"/>

                            <!-- Thumb Middle -->
                            <body name="thumb_middle" pos="0.04407 0.034553 -0.0008" quat="1 0 0 0">
                                <joint name="joint_thumb_middle" type="hinge" pos="0 0 0" axis="0 0 1" range="0 0.68" limited="true" damping="3"/>
                                <geom name="thumb_middle_vis" type="mesh" mesh="thumb_middle_vis" material="thumb_material" group="1" contype="0" conaffinity="0"/>
                                <geom name="thumb_middle_col" type="mesh" mesh="thumb_middle_col" mass="0.1" />
                                <site name="site_thumb_middle" size="0.01" material="site_right_hand"/>

                                <!-- Thumb Distal -->
                                <body name="thumb_distal" pos="0.020248 0.010156 -0.0012" quat="1 0 0 0">
                                    <joint name="joint_thumb_distal" type="hinge" pos="0 0 0" axis="0 0 1" range="0 0.77" limited="true" damping="3"/>
                                    <geom name="thumb_distal_vis" type="mesh" mesh="thumb_distal_vis" material="thumb_distal_material" group="1" contype="0" conaffinity="0"> </geom>
                                    <geom name="thumb_distal_col" type="mesh" mesh="thumb_distal_col" mass="0.1" />
                                    <site name="thumb_tip" size="0.01" material="site_right_hand"/>
                                </body>
                                <!-- End of Thumb Distal -->
                            </body>
                            <!-- End of Thumb Middle -->
                        </body>
                        <!-- End of Thumb Proximal 2 -->
                    </body>
                    <!-- End of Thumb Proximal 1 -->
                </body>
                <!-- End of Thumb -->

                <!-- Index finger -->
                <body name="index" pos="0 0 0">
                    <!-- Index Proximal -->
                    <!-- <body name="index_proximal" pos="0.0022853 -0.10493 -0.032268" quat="0.01745 -0.99985 0.0 0.0"> -->
                    <body name="index_proximal" pos="0.0015 -0.130 -0.032268" quat="0.01745 -0.99985 0.0 0.0">
                        <joint name="joint_index_proximal" type="hinge" pos="0 0 0" axis="0 0 1" range="0 1.62" limited="true" damping="3"/>
                        <site name="site_index_proximal" size="0.01" material="site_right_hand"/>
                        <geom name="index_proximal_vis" type="mesh" mesh="index_proximal_vis" material="index_material" group="1" contype="0" conaffinity="0"/>
                        <geom name="index_proximal_col" type="mesh" mesh="index_proximal_col" mass="0.1" />
                        <!-- Index Distal -->
                        <body name="index_distal" pos="-0.0026138 0.032026 -0.001" quat="1 0 0 0">
                            <joint name="joint_index_distal" type="hinge" pos="0 0 0" axis="0 0 1" range="0 1.82" limited="true" damping="3"/>
                            <site name="index_tip" size="0.01" material="site_right_hand"/>
                            <geom name="index_distal_vis" type="mesh" mesh="index_distal_vis" material="index_material" group="1" contype="0" conaffinity="0"/>
                            <geom name="index_distal_col" type="mesh" mesh="index_distal_col" mass="0.1" />
                        </body>
                        <!-- End of Index Distal -->
                    </body>
                    <!-- End of Index Proximal -->
                </body>
                <!-- End of Index finger -->
                <!-- Middle finger -->
                <body name="middle" pos="0 0 0">
                    <!-- Middle Proximal -->
                    <!-- <body name="middle_proximal" pos="0.0022853 -0.1055 -0.01295" quat="0 -1 0.0 0.0"> -->
                    <body name="middle_proximal" pos="0.0015 -0.1305 -0.01295" quat="0 -1 0.0 0.0">
                        <joint name="joint_middle_proximal" type="hinge" pos="0 0 0" axis="0 0 1" range="0 1.62" limited="true" damping="3"/>
                        <site name="site_middle_proximal" size="0.01" material="site_right_hand"/>
                        <geom name="middle_proximal_vis" type="mesh" mesh="middle_proximal_vis" material="middle_material" group="1" contype="0" conaffinity="0"/>
                        <geom name="middle_proximal_col" type="mesh" mesh="middle_proximal_col" mass="0.1" />
                        <!-- Middle Distal -->
                        <body name="middle_distal" pos="-0.0024229 0.032041 -0.001" quat="1 0 0 0">
                            <joint name="joint_middle_distal" type="hinge" pos="0 0 0" axis="0 0 1" range="0 1.82" limited="true" damping="3"/>
                            <site name="middle_tip" size="0.01" material="site_right_hand"/>
                            <geom name="middle_distal_vis" type="mesh" mesh="middle_distal_vis" material="middle_material" group="1" contype="0" conaffinity="0"/>
                            <geom name="middle_distal_col" type="mesh" mesh="middle_distal_col" mass="0.1" />
                        </body>
                        <!-- End of Middle Distal -->
                    </body>
                    <!-- End of Middle Proximal -->
                </body>
                <!-- End of Middle finger -->

                <!-- Ring finger -->
                <body name="ring" pos="0 0 0">
                    <!-- Ring Proximal -->
                    <!-- <body name="ring_proximal" pos="0.0022853 -0.10531 0.0062872" quat="0.02619 0.99966 0.0 0.0"> -->
                    <body name="ring_proximal" pos="0.0015 -0.13031 0.0062872" quat="0.02619 0.99966 0.0 0.0">
                        <joint name="joint_ring_proximal" type="hinge" pos="0 0 0" axis="0 0 1" range="0 1.62" limited="true" damping="3"/>
                        <site name="site_ring_proximal" size="0.01" material="site_right_hand"/>
                        <geom name="ring_proximal_vis" type="mesh" mesh="ring_proximal_vis" material="ring_material" group="1" contype="0" conaffinity="0"/>
                        <geom name="ring_proximal_col" type="mesh" mesh="ring_proximal_col" mass="0.1" />
                        <!-- Ring Distal -->
                        <body name="ring_distal" pos="-0.0024229 0.032041 -0.001" quat="1 0 0 0">
                            <joint name="joint_ring_distal" type="hinge" pos="0 0 0" axis="0 0 1" range="0 1.75" limited="true" damping="3"/>
                            <site name="ring_tip" size="0.01" material="site_right_hand"/>
                            <geom name="ring_distal_vis" type="mesh" mesh="ring_distal_vis" material="ring_material" group="1" contype="0" conaffinity="0"/>
                            <geom name="ring_distal_col" type="mesh" mesh="ring_distal_col" mass="0.1" />
                        </body>
                        <!-- End of Ring Distal -->
                    </body>
                    <!-- End of Ring Proximal -->
                </body>
                <!-- End of Ring finger -->

                <!-- Pinky finger -->
                <body name="pinky" pos="0 0 0">
                    <!-- Pinky Proximal -->
                    <!-- <body name="pinky_proximal" pos="0.0022853 -0.10411 0.025488" quat="0.05232 0.99863 0.0 0.0"> -->
                    <body name="pinky_proximal" pos="0.0015 -0.12911 0.025488" quat="0.05232 0.99863 0.0 0.0">
                        <joint name="joint_pinky_proximal" type="hinge" pos="0 0 0" axis="0 0 1" range="0 1.62" limited="true" damping="3"/>
                        <site name="site_pinky_proximal" size="0.01" material="site_right_hand"/>
                        <geom name="pinky_proximal_vis" type="mesh" mesh="pinky_proximal_vis" material="pinky_material" group="1" contype="0" conaffinity="0"/>
                        <geom name="pinky_proximal_col" type="mesh" mesh="pinky_proximal_col" mass="0.1" />
                        <!-- Pinky Distal -->
                        <body name="pinky_distal" pos="-0.0024229 0.032041 -0.001" quat="1 0 0 0">
                            <joint name="joint_pinky_distal" type="hinge" pos="0 0 0" axis="0 0 1" range="0 1.87" limited="true" damping="3"/>
                            <site name="little_tip" size="0.01" material="site_right_hand"/>
                            <geom name="pinky_distal_vis" type="mesh" mesh="pinky_distal_vis" material="pinky_material" group="1" contype="0" conaffinity="0"/>
                            <geom name="pinky_distal_col" type="mesh" mesh="pinky_distal_col" mass="0.1" />
                        </body>
                        <!-- End of Pinky Distal -->
                    </body>
                    <!-- End of Pinky Proximal -->
                </body>
                <!-- End of Pinky finger -->

            </body>
            <!-- End of Palm -->
        </body>
    </worldbody>
    <contact>
        <exclude name="exclude_rh_palm_thumb_proximal_1" body1="thumb_proximal_1" body2="palm"/>
        <exclude name="exclude_rh_palm_thumb_proximal_1_proximal_2" body1="thumb_proximal_1" body2="thumb_proximal_2"/>
        <exclude name="exclude_rh_palm_thumb_proximal_2" body1="thumb_proximal_2" body2="palm"/>
        <exclude name="exclude_rh_palm_thumb_middle_2" body1="thumb_middle" body2="palm"/>
        <exclude name="exclude_rh_thumb_proximal_2_middle" body1="thumb_proximal_2" body2="thumb_middle"/>
        <exclude name="exclude_rh_thumb_middle_distal" body1="thumb_middle" body2="thumb_distal"/>
        <exclude name="exclude_rh_palm_index_proximal" body1="index_proximal" body2="palm"/>
        <exclude name="exclude_rh_palm_middle_proximal" body1="middle_proximal" body2="palm"/>
        <exclude name="exclude_rh_palm_ring_proximal" body1="ring_proximal" body2="palm"/>
        <exclude name="exclude_rh_palm_pinky_proximal" body1="pinky_proximal" body2="palm"/>
    </contact>

    <equality>
        <joint joint1="joint_thumb_proximal_2" joint2="joint_thumb_middle" polycoef="0 1.0 0 0 0"
            solimp="0.95 0.99 0.001" solref="0.005 1"/>
        <joint joint1="joint_thumb_proximal_2" joint2="joint_thumb_distal" polycoef="0 1.13 0 0 0"
            solimp="0.95 0.99 0.001" solref="0.005 1"/>
        <joint joint1="joint_index_proximal" joint2="joint_index_distal" polycoef="0 1.13 0 0 0"
            solimp="0.95 0.99 0.001" solref="0.005 1"/>
        <joint joint1="joint_middle_proximal" joint2="joint_middle_distal" polycoef="0 1.13 0 0 0"
            solimp="0.95 0.99 0.001" solref="0.005 1"/>
        <joint joint1="joint_ring_proximal" joint2="joint_ring_distal" polycoef="0 1.08 0 0 0"
            solimp="0.95 0.99 0.001" solref="0.005 1"/>
        <joint joint1="joint_pinky_proximal" joint2="joint_pinky_distal" polycoef="0 1.15 0 0 0"
            solimp="0.95 0.99 0.001" solref="0.005 1"/>

    </equality>


    <actuator>
        <!-- <motor joint="joint_thumb_proximal_1" ctrllimited="true" ctrlrange="-1 1" name="thumb_proximal_1_drive"/>
        <motor joint="joint_thumb_proximal_2" ctrllimited="true" ctrlrange="-1 1" name="thumb_proximal_2_drive"/>
        <motor joint="joint_index_proximal" ctrllimited="true" ctrlrange="-1 1" name="index_proximal_drive"/>
        <motor joint="joint_middle_proximal" ctrllimited="true" ctrlrange="-1 1" name="middle_proximal_drive"/>
        <motor joint="joint_ring_proximal" ctrllimited="true" ctrlrange="-1 1" name="ring_proximal_drive"/>
        <motor joint="joint_pinky_proximal" ctrllimited="true" ctrlrange="-1 1" name="pinky_proximal_drive"/>
 -->

        <position joint="joint_thumb_proximal_1" name="thumb_proximal_1_drive" ctrlrange="0 1.3"  kp="100" forcelimited="true" forcerange="-20 20"/>
        <position joint="joint_thumb_proximal_2" name="thumb_proximal_2_drive" ctrlrange="0 0.68" kp="100" forcelimited="true" forcerange="-20 20"/>
        <position joint="joint_index_proximal" name="index_proximal_drive" ctrlrange="0 1.62"  kp="100" forcelimited="true" forcerange="-20 20"/>
        <position joint="joint_middle_proximal" name="middle_proximal_drive" ctrlrange="0 1.62" kp="100" forcelimited="true" forcerange="-20 20"/>
        <position joint="joint_ring_proximal" name="ring_proximal_drive" ctrlrange="0 1.62" kp="100" forcelimited="true" forcerange="-20 20"/>
        <position joint="joint_pinky_proximal" name="pinky_proximal_drive" ctrlrange="0 1.62" kp="100" forcelimited="true" forcerange="-20 20"/>


    </actuator>

    <sensor>
            <force name="force_ee" site="ft_frame"/>
            <torque name="torque_ee" site="ft_frame"/>
    </sensor>

</mujoco>